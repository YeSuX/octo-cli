{
  "name": "octo-cli",
  "version": "0.1.0",
  "description": "OctoCLI Phase A minimal CLI kernel",
  "type": "module",
  "private": true,
  "bin": {
    "octo": "./dist/main.js"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {}
}
